model User {
    id       String     @id @default(uuid())
    name     String     @db.VarChar(100)
    email    String     @unique
    password String
    role     UserRole
    phone    String?
    status   UserStatus @default(ACTIVE)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    properties      Property[]
    rentalRequestes RentalRequest[]
    payments        Payment[]
    reviews         Review[]

    @@map("users")
}
