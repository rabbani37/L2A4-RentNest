model Property {
    id           String               @id @default(uuid())
    title        String
    description  String
    price        Decimal              @default(0.00) @db.Decimal(10, 2)
    location     String
    city         String
    bedrooms     Int
    buthrooms    Int
    size         Float
    amenities    String[]
    images       String[]
    availability PropertyAvailability
    categoryId   String
    category     Category             @relation(fields: [categoryId], references: [id], onDelete: Cascade)
    landlordId   String
    landlor      User                 @relation(fields: [landlordId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    rentalRequests RentalRequest[]
    reviews        Review[]

    @@map("properties")
}
